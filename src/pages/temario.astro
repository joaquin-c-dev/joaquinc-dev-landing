---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getNavCourses } from "@/lib/courses";
import Temario from "@/screens/Temario";

const navCourses = await getNavCourses();
---

<BaseLayout
  title="Temario del Curso de Java | Joaquín C. Dev"
  description="Revisa el temario completo del curso de Java: desde fundamentos y POO hasta colecciones, manejo de errores y bases de datos, con horas de contenido práctico."
  keywords="temario java, contenido curso java, módulos java, programa de estudio java"
>
  <Temario client:load navCourses={navCourses} />
</BaseLayout>
