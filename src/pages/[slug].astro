---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCourseBySlug, getNavCourses } from "@/lib/courses";
import CoursePage from "@/screens/CoursePage";

const { slug } = Astro.params;
const [course, navCourses] = await Promise.all([
  getCourseBySlug(slug),
  getNavCourses(),
]);

if (!course) {
  return Astro.rewrite("/404");
}
---

<BaseLayout
  title={course.seo.title}
  description={course.seo.description}
  keywords={course.seo.keywords}
  ogImage={course.seo.ogImage}
  ogType="website"
>
  <CoursePage client:load course={course} navCourses={navCourses} pathname={Astro.url.pathname} />
</BaseLayout>
