---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getNavCourses } from "@/lib/courses";
import PrivacyPolicy from "@/screens/PrivacyPolicy";

const navCourses = await getNavCourses();
---

<BaseLayout
  title="Políticas de Privacidad | Joaquín C. Dev"
  description="Políticas de privacidad para los cursos de programación de Joaquín C. Dev: cómo recopilamos, usamos y protegemos tu información personal."
  noindex={true}
>
  <PrivacyPolicy client:load navCourses={navCourses} />
</BaseLayout>
