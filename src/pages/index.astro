---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getHomeCourses, getNavCourses } from "@/lib/courses";
import Index from "@/screens/Index";

const [homeCourses, navCourses] = await Promise.all([
  getHomeCourses(),
  getNavCourses(),
]);
---

<BaseLayout
  title="Java y Spring con Joaquín C. Dev"
  description="Transforma tu futuro en tecnología: empieza hoy con Java y Spring para desarrollar habilidades que abrirán nuevas oportunidades."
  keywords="java, curso java, programación java, aprender java, java desde cero, desarrollo java, spring boot"
>
  <Index client:load courses={homeCourses} navCourses={navCourses} />
</BaseLayout>
