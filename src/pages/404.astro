---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getNavCourses } from "@/lib/courses";
import NotFound from "@/screens/NotFound";

const navCourses = await getNavCourses();
---

<BaseLayout
  title="Página no encontrada (404) | Joaquín C. Dev"
  description="La página que buscas no existe. Vuelve al inicio para explorar los cursos de Java y programación."
  noindex={true}
>
  <NotFound client:load navCourses={navCourses} pathname={Astro.url.pathname} />
</BaseLayout>
