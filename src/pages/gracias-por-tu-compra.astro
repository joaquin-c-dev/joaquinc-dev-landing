---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getNavCourses } from "@/lib/courses";
import GraciasPorTuCompra from "@/screens/GraciasPorTuCompra";

const navCourses = await getNavCourses();
---

<BaseLayout
  title="¡Gracias por tu compra! | Joaquín C. Dev"
  description="Tu inscripción ha sido procesada exitosamente. Revisa tu correo para los detalles del curso y los próximos pasos."
  noindex={true}
>
  <GraciasPorTuCompra client:load navCourses={navCourses} pathname={Astro.url.pathname} />
</BaseLayout>
